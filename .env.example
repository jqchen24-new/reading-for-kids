# Server-only on Vercel (Dashboard → Environment Variables). Never prefix with VITE_.
ANTHROPIC_API_KEY=

# Optional override (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=

# Optional: natural kid-friendly narration (server TTS). Read aloud uses this first; browser voices are fallback.
# If both OpenAI and Gemini keys are set, auto tries OpenAI first, then Gemini if OpenAI fails (quota, etc.).
# Set TTS_PROVIDER=gemini to use only Gemini. Set TTS_PROVIDER=openai to use only OpenAI.
# TTS_PROVIDER=auto|openai|gemini

# OpenAI — https://platform.openai.com/docs/guides/text-to-speech
# OPENAI_API_KEY=
# OPENAI_TTS_MODEL=tts-1-hd
# OPENAI_TTS_VOICE=nova
# OPENAI_TTS_SPEED=0.92
# When auto + Gemini fallback: abort OpenAI attempt after this many ms so Gemini runs sooner (default 4500).
# OPENAI_TTS_FAILFAST_MS=4500

# Scene pictures (Gemini native image API — billed per image). Runs after each scene loads.
# Uses the same GEMINI_API_KEY as TTS. Enable explicitly (1, true, yes, or on):
# SCENE_ILLUSTRATIONS=1
# Local dev: put .env in this folder (next to package.json). Vite loads that file even if your
# terminal's current directory is a parent folder. Restart npm run dev after changing .env.
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Aspect ratio: plain string, e.g. 16:9 (sent as generationConfig.imageConfig, not responseFormat).
# GEMINI_IMAGE_ASPECT_RATIO=16:9

# Google Gemini native TTS (Preview) — https://ai.google.dev/gemini-api/docs/speech-generation
# Use a key from https://aistudio.google.com/app/apikey (copy exactly, no spaces).
# If Google Cloud shows "API key not valid": wrong/expired key, or the key is restricted to
# "HTTP referrers" only — server-side /api/tts has no browser referrer; use "None" for app
# restrictions for local dev, or create an unrestricted key for the backend.
# GEMINI_API_KEY=
# (same value works as GOOGLE_GENERATIVE_AI_API_KEY or GOOGLE_AI_API_KEY if you already use those names)
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# If Google returns 503 UNAVAILABLE, wait and retry or try e.g. gemini-3.1-flash-tts-preview
# GEMINI_TTS_VOICE=Achird
# GEMINI_TTS_MAX_CHARS=6000
